generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "tenant"]
}

// ========== ENUMS ==========
enum UserRole {
  super_admin
  admin
  gerente
  operador
  visualizador
}

enum TenantStatus {
  active
  inactive
  suspended
  trial
  canceled
}

enum PlanoStatus {
  active
  inactive
}

enum AssinaturaStatus {
  active
  inactive
  canceled
  past_due
  trial
}

enum TvStatus {
  online
  offline
  paused
  error
}

enum MidiaType {
  image
  video
  audio
  url
  html
}

enum MidiaStatus {
  processing
  ready
  error
}

enum CampanhaStatus {
  draft
  active
  paused
  completed
  canceled
}

enum AgendamentoStatus {
  scheduled
  playing
  completed
  canceled
}

enum PagamentoStatus {
  pending
  confirmed
  received
  canceled
  refunded
  chargeback
}

enum FaturaStatus {
  pending
  paid
  canceled
  overdue
  refunded
}

enum PlaylistTipo {
  principal
  promocional
  institucional
  emergencia
  custom
}

enum DiaSemana {
  domingo
  segunda
  terca
  quarta
  quinta
  sexta
  sabado
}

// ========== TENANT SCHEMA ==========
model Tenant {
  id            String          @id @default(uuid()) @db.Uuid
  nome          String
  slug          String          @unique
  documento     String?
  email         String?
  telefone      String?
  logoUrl       String?
  status        TenantStatus    @default(trial)
  planoTipo     String?
  maxEstabelecimentos Int       @default(1)
  maxTvs        Int             @default(1)
  maxMidias     Int             @default(50)
  maxArmazenamentoMb Int        @default(500)
  trialEndsAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  usuarios          Usuario[]
  estabelecimentos  Estabelecimento[]
  assinaturas       Assinatura[]
  auditLogs         AuditLog[]

  @@map("tenants")
}

model Usuario {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique
  passwordHash   String
  nome           String
  avatarUrl      String?
  role           UserRole  @default(operador)
  telefone       String?
  ativo          Boolean   @default(true)
  doisFatoresAtivo Boolean @default(false)
  doisFatoresSecret String?
  ultimoLogin    DateTime?
  refreshToken   String?
  tenantId       String    @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  estabelecimentos UsuarioEstabelecimento[]
  auditLogs      AuditLog[]

  @@index([tenantId])
  @@index([email])
  @@map("usuarios")
}

model Estabelecimento {
  id              String   @id @default(uuid()) @db.Uuid
  nome            String
  slug            String
  documento       String?
  endereco        String?
  cidade          String?
  estado          String?
  cep             String?
  telefone        String?
  latitude        Float?
  longitude       Float?
  horarioAbertura String?
  horarioFechamento String?
  ativo           Boolean  @default(true)
  tenantId        String   @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuarios        UsuarioEstabelecimento[]
  tvs             Tv[]
  campanhas       Campanha[]

  @@index([tenantId])
  @@index([slug])
  @@map("estabelecimentos")
}

model UsuarioEstabelecimento {
  usuarioId         String @db.Uuid
  estabelecimentoId String @db.Uuid

  usuario         Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  estabelecimento Estabelecimento @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)

  @@id([usuarioId, estabelecimentoId])
  @@map("usuarios_estabelecimentos")
}

model Tv {
  id              String    @id @default(uuid()) @db.Uuid
  nome            String
  identificador   String    @unique
  descricao       String?
  modelo          String?
  resolucao       String?
  status          TvStatus  @default(offline)
  ipAddress       String?
  lastPingAt      DateTime?
  volume          Int       @default(50)
  rotacaoAutomatica Boolean @default(true)
  intervaloRotacao Int      @default(15)
  estabelecimentoId String  @db.Uuid
  tenantId        String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  estabelecimento Estabelecimento @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)
  agendamentos    Agendamento[]
  playlistAtual   PlaylistItem?  @relation("TvPlaylistAtual")

  @@index([tenantId])
  @@index([identificador])
  @@index([estabelecimentoId])
  @@map("tvs")
}

model Midia {
  id          String       @id @default(uuid()) @db.Uuid
  nome        String
  descricao   String?
  tipo        MidiaType
  mimeType    String
  tamanho     Int
  duracao     Int?
  largura     Int?
  altura      Int?
  url         String
  thumbnailUrl String?
  hash        String?
  status      MidiaStatus  @default(processing)
  tags        String?
  pasta       String?
  tenantId    String       @db.Uuid
  uploadedById String      @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy   Usuario     @relation(fields: [uploadedById], references: [id])
  playlistItems PlaylistItem[]
  campanhaMidias CampanhaMidia[]

  @@index([tenantId])
  @@index([tipo])
  @@map("midias")
}

model Campanha {
  id              String          @id @default(uuid()) @db.Uuid
  nome            String
  descricao       String?
  tipo            PlaylistTipo    @default(promocional)
  status          CampanhaStatus  @default(draft)
  dataInicio      DateTime?
  dataFim         DateTime?
  prioridade      Int             @default(0)
  tenantId        String          @db.Uuid
  estabelecimentoId String?       @db.Uuid
  criadoPorId     String          @db.Uuid
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  estabelecimento Estabelecimento? @relation(fields: [estabelecimentoId], references: [id])
  criadoPor       Usuario         @relation(fields: [criadoPorId], references: [id])
  midias          CampanhaMidia[]
  agendamentos    Agendamento[]

  @@index([tenantId])
  @@index([status])
  @@map("campanhas")
}

model CampanhaMidia {
  id         String   @id @default(uuid()) @db.Uuid
  campanhaId String   @db.Uuid
  midiaId    String   @db.Uuid
  ordem      Int      @default(0)
  duracao    Int?
  createdAt  DateTime @default(now())

  campanha   Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  midia      Midia    @relation(fields: [midiaId], references: [id], onDelete: Cascade)

  @@unique([campanhaId, midiaId])
  @@map("campanhas_midias")
}

model Agendamento {
  id          String              @id @default(uuid()) @db.Uuid
  nome        String
  descricao   String?
  diasSemana  DiaSemana[]
  horarioInicio String
  horarioFim  String?
  dataInicio  DateTime
  dataFim     DateTime?
  status      AgendamentoStatus   @default(scheduled)
  recorrente  Boolean             @default(true)
  tvId        String              @db.Uuid
  campanhaId  String?             @db.Uuid
  playlistId  String?             @db.Uuid
  tenantId    String              @db.Uuid
  criadoPorId String              @db.Uuid
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tv          Tv                  @relation(fields: [tvId], references: [id], onDelete: Cascade)
  campanha    Campanha?           @relation(fields: [campanhaId], references: [id])
  playlist    Playlist?           @relation(fields: [playlistId], references: [id])
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  criadoPor   Usuario             @relation(fields: [criadoPorId], references: [id])

  @@index([tenantId])
  @@index([tvId])
  @@index([status])
  @@map("agendamentos")
}

model Playlist {
  id          String        @id @default(uuid()) @db.Uuid
  nome        String
  descricao   String?
  tipo        PlaylistTipo  @default(custom)
  tenantId    String        @db.Uuid
  criadoPorId String        @db.Uuid
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  criadoPor   Usuario       @relation(fields: [criadoPorId], references: [id])
  itens       PlaylistItem[]
  agendamentos Agendamento[]

  @@index([tenantId])
  @@map("playlists")
}

model PlaylistItem {
  id         String   @id @default(uuid()) @db.Uuid
  playlistId String   @db.Uuid
  midiaId    String   @db.Uuid
  ordem      Int
  duracao    Int?
  tvId       String?  @db.Uuid
  createdAt  DateTime @default(now())

  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  midia      Midia    @relation(fields: [midiaId], references: [id], onDelete: Cascade)
  tvAtual    Tv?      @relation("TvPlaylistAtual", fields: [tvId], references: [id])

  @@unique([playlistId, midiaId, ordem])
  @@index([playlistId])
  @@map("playlist_itens")
}

model Assinatura {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @unique @db.Uuid
  asaasId       String?
  planoTipo     String
  status        AssinaturaStatus  @default(trial)
  dataInicio    DateTime          @default(now())
  dataFim       DateTime?
  valor         Decimal           @default(0) @db.Decimal(10, 2)
  ciclo         String            @default("monthly")
  trialEndsAt   DateTime?
  canceladoEm   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  faturas       Fatura[]

  @@map("assinaturas")
}

model Fatura {
  id            String        @id @default(uuid()) @db.Uuid
  assinaturaId  String        @db.Uuid
  asaasId       String?
  asaasInvoiceId String?
  valor         Decimal       @db.Decimal(10, 2)
  status        FaturaStatus  @default(pending)
  dataVencimento DateTime
  dataPagamento  DateTime?
  urlBoleto     String?
  urlPix        String?
  linhaDigitable String?
  cicloReferencia String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assinatura    Assinatura    @relation(fields: [assinaturaId], references: [id], onDelete: Cascade)

  @@index([assinaturaId])
  @@map("faturas")
}

model Plano {
  id               String   @id @default(uuid()) @db.Uuid
  nome             String   @unique
  slug             String   @unique
  descricao        String?
  valor            Decimal  @db.Decimal(10, 2)
  ciclo            String   @default("monthly")
  maxEstabelecimentos Int   @default(1)
  maxTvs           Int      @default(1)
  maxMidias        Int      @default(50)
  maxArmazenamentoMb Int    @default(500)
  recursos         String?
  status           PlanoStatus @default(active)
  ordem            Int      @default(0)
  destaque         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("planos")
}

model Pagamento {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @db.Uuid
  asaasId         String?
  asaasPaymentId  String?
  valor           Decimal         @db.Decimal(10, 2)
  taxa            Decimal         @default(0) @db.Decimal(10, 2)
  status          PagamentoStatus @default(pending)
  metodo          String?
  descricao       String?
  metadata        Json?
  paymentUrl      String?
  pixCopiaECola   String?
  boletoUrl       String?
  boletoCodigo    String?
  cardLastDigits  String?
  dataPagamento   DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId])
  @@map("pagamentos")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String
  userId    String   @db.Uuid
  tenantId  String   @db.Uuid
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user      Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}