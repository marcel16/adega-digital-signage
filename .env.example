# ===== Database =====
DATABASE_URL=postgresql://adega:adega_secret_2024@postgres:5432/adega_signage?schema=public

# ===== Redis =====
REDIS_URL=redis://:adega_redis_2024@redis:6379

# ===== JWT =====
JWT_SECRET=change_this_to_a_random_64_char_secret
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ===== Argon2 =====
ARGON2_SECRET=change_this_argon2_pepper

# ===== URLs =====
APP_URL=https://adega.queroservico.store
ADMIN_URL=https://admin.adega.queroservico.store
API_URL=https://api.adega.queroservico.store
IPTV_URL=https://tv.adega.queroservico.store
STORAGE_URL=https://api.adega.queroservico.store/storage

# ===== Ports =====
API_PORT=4000
WEB_PORT=3000
ADMIN_PORT=3001
IPTV_PORT=4001
POSTGRES_PORT=5432
REDIS_PORT=6379

# ===== Asaas =====
ASAAS_API_KEY=
ASAAS_ENV=sandbox

# ===== Storage =====
STORAGE_DRIVER=local
UPLOAD_DIR=./storage/uploads
MAX_FILE_SIZE=104857600

# ===== Admin =====
ADMIN_EMAIL=admin@adegasignage.com
ADMIN_PASSWORD=Admin@123456

# ===== Security =====
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
CORS_ORIGINS=https://adega.queroservico.store,https://admin.adega.queroservico.store,https://api.adega.queroservico.store
BCRYPT_SALT_ROUNDS=12

# ===== System =====
NODE_ENV=production
LOG_LEVEL=info
TRIAL_DAYS=7
DEFAULT_MAX_STORES=1
DEFAULT_MAX_TVS=1
DEFAULT_MAX_MEDIA=50
DEFAULT_MAX_STORAGE_MB=500
